    "items": [
      { "q": "이 플랫폼은 어떤 서비스인가요?", "a": "CareTalk은 외국인 간병인과 환자·보호자·의료진 간의 언어 장벽을 해소하는 간병 전문 통역·기록·전달 플랫폼입니다." },
      { "q": "회원가입 없이 사용할 수 있나요?", "a": "네, 커뮤니티 게시물 등록을 포함한 대부분의 기능을 회원가입 없이 무료로 이용할 수 있습니다." },
      { "q": "간병인과 환자 간 통역이 가능한가요?", "a": "네, 간병인의 외국어를 한국어로, 환자의 한국어를 간병인 언어로 실시간 번역합니다." },
      { "q": "어떤 언어를 지원하나요?", "a": "한국어, 영어, 중국어, 일본어, 프랑스어, 독일어, 러시아어, 베트남어, 힌디어, 포르투갈어, 인도네시아어, 아랍어, 스페인어, 태국어, 몽골어 등 19개 언어를 지원합니다." },
      { "q": "음성 통역도 가능한가요?", "a": "네, 마이크 버튼을 누르고 말하면 음성이 텍스트로 변환된 후 자동 번역됩니다." },
      { "q": "환자 말을 간병인 언어로 바꿀 수 있나요?", "a": "네, '환자 → 간병인 언어' 모드를 선택하면 환자의 한국어 발화가 간병인 언어로 번역됩니다." },
      { "q": "간병인 말을 한국어로 바꿀 수 있나요?", "a": "네, '간병인 → 한국어' 모드를 선택하면 간병인의 외국어 발화가 한국어로 번역됩니다." },
      { "q": "간병일지는 어떻게 작성하나요?", "a": "간병일지 메뉴에서 환자 상태, 식사, 복약, 수면, 특이사항 등을 입력하거나 음성으로 녹음할 수 있습니다." },
      { "q": "음성녹음이 텍스트로 바뀌나요?", "a": "네, 30초 단위 음성녹음이 자동으로 텍스트로 변환됩니다." },
      { "q": "간병일지를 보호자에게 보낼 수 있나요?", "a": "네, 작성된 간병일지를 카카오톡, 텔레그램, PDF로 보호자에게 전달할 수 있습니다." },
      { "q": "카카오톡 전달이 가능한가요?", "a": "네, 번역 결과·간병일지·OCR 결과를 카카오톡으로 공유할 수 있습니다." },
      { "q": "텔레그램 전달이 가능한가요?", "a": "네, 번역 결과·간병일지·OCR 결과를 텔레그램으로 공유할 수 있습니다." },
      { "q": "처방전 사진 분석이 가능한가요?", "a": "네, 처방전 사진을 업로드하면 텍스트를 추출하고 한국어로 요약해 드립니다." },
      { "q": "약 사진을 업로드할 수 있나요?", "a": "네, 약봉투 사진을 업로드하면 약 정보를 텍스트로 추출하고 번역해 드립니다." },
      { "q": "수액 사진도 분석할 수 있나요?", "a": "네, 수액 라벨 사진을 분석하여 성분과 용량 정보를 텍스트로 변환합니다." },
      { "q": "OCR 결과를 번역할 수 있나요?", "a": "네, OCR로 추출된 텍스트를 선택한 언어로 번역하여 보호자·의료진에게 전달할 수 있습니다." },
      { "q": "간병인 구인 게시물을 올릴 수 있나요?", "a": "네, 커뮤니티 '간병인 찾아요' 게시판에 회원가입 없이 무료로 구인 게시물을 올릴 수 있습니다." },
      { "q": "간병인 구직 게시물을 올릴 수 있나요?", "a": "네, 커뮤니티 '간병인 해요' 게시판에 자격증, 경력, 가능 언어 등을 포함한 구직 게시물을 올릴 수 있습니다." },
      { "q": "게시물 수정이 가능한가요?", "a": "네, 등록한 게시물은 수정 버튼을 통해 언제든지 내용을 수정할 수 있습니다." },
      { "q": "사진 업로드가 가능한가요?", "a": "네, PC 파일 업로드, 휴대폰 카메라 촬영, 갤러리 업로드 모두 지원합니다." },
      { "q": "휴대폰에서도 사용할 수 있나요?", "a": "네, 모바일 최적화 UI가 적용되어 스마트폰에서도 편리하게 사용할 수 있습니다." },
      { "q": "PC에서도 화면이 꽉 차게 보이나요?", "a": "네, PC에서는 와이드 화면을 최대한 활용하는 Dense UI로 설계되었습니다." },
      { "q": "채팅 기능이 있나요?", "a": "네, 게시물마다 채팅 버튼이 있어 바로 상대방과 채팅할 수 있습니다." },
      { "q": "관리자와 상담할 수 있나요?", "a": "네, 화면 왼쪽 하단의 상담 버튼을 클릭하면 관리자와 실시간 채팅 상담을 할 수 있습니다." },
      { "q": "자동번역 채팅이 가능한가요?", "a": "네, 채팅창에서 자동번역 기능을 켜면 메시지가 자동으로 상대방 언어로 번역되어 전달됩니다." },
      { "q": "영상통화 기능이 있나요?", "a": "네, 채팅창에서 영상통화 버튼을 클릭하여 영상통화를 시작할 수 있습니다." },
      { "q": "음성통화 기능이 있나요?", "a": "네, 채팅창에서 음성통화 버튼을 클릭하여 음성통화를 시작할 수 있습니다." },
      { "q": "지도 안내가 가능한가요?", "a": "네, 게시물의 약도 버튼을 클릭하면 OpenStreetMap 기반의 지도로 위치를 확인할 수 있습니다." },
      { "q": "모든 기능이 무료인가요?", "a": "네, CareTalk의 모든 기능은 완전 무료로 제공됩니다." },
      { "q": "의료 진단 서비스인가요?", "a": "아닙니다. 본 플랫폼은 의료 진단 서비스가 아니라 간병·통역·기록·전달을 돕는 보조 플랫폼입니다. OCR 분석 결과는 참고용 텍스트 분석이며, 치료 판단은 반드시 의사·간호사 등 의료진 확인이 필요합니다." }
    ]
  },
